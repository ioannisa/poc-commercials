<configuration>
    <!--
      stdout is reserved for the MCP protocol channel, so ALL logging must go to
      stderr. (The default ConsoleAppender target is System.out, which would
      corrupt the JSON-RPC stream.)
    -->
    <appender name="STDERR" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{24} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="STDERR"/>
    </root>
</configuration>
